{
  "name": "verno",
  "displayName": "Verno — AI SDLC Automation Engine",
  "description": "Voice-first multi-agent AI assistant that automates the full Software Development Life Cycle inside VSCode.",
  "version": "1.0.0",
  "publisher": "MuhammadAbuzar-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/maybeanns/Verno"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "media/logo.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "verno.processInput",
        "title": "Verno: Process User Input"
      },
      {
        "command": "verno.startRecording",
        "title": "Verno: Start Recording"
      },
      {
        "command": "verno.stopRecording",
        "title": "Verno: Stop Recording"
      },
      {
        "command": "verno.manageAgents",
        "title": "Verno: Manage Agents"
      },
      {
        "command": "verno.generateCode",
        "title": "Verno: Generate Code"
      },
      {
        "command": "verno.showDiff",
        "title": "Verno: Show Diff"
      },
      {
        "command": "verno.showOutput",
        "title": "Verno: Show Verno Output"
      },
      {
        "command": "verno.revealSidebar",
        "title": "Verno: Reveal Sidebar"
      },
      {
        "command": "verno.newConversation",
        "title": "Verno: New Conversation"
      },
      {
        "command": "verno.processVoiceInput",
        "title": "Verno: Process Voice Input"
      },
      {
        "command": "verno.clearApiKeys",
        "title": "Verno: Clear Stored API Keys"
      },
      {
        "command": "verno.startSDLC",
        "title": "Verno: Start SDLC Pipeline"
      },
      {
        "command": "verno.generateObservability",
        "title": "Verno: Generate Observability Artifacts"
      },
      {
        "command": "verno.generateOwaspChecklist",
        "title": "Verno: Generate OWASP Checklist"
      },
      {
        "command": "verno.checkCompliance",
        "title": "Verno: Check PRD Compliance (GDPR/HIPAA)"
      },
      {
        "command": "verno.scanForSecrets",
        "title": "Verno: Scan for Secrets"
      },
      {
        "command": "verno.installSecretScanner",
        "title": "Verno: Install Pre-Commit Secret Scanner"
      },
      {
        "command": "verno.uninstallSecretScanner",
        "title": "Verno: Uninstall Secret Scanner Hook"
      },
      {
        "command": "verno.generateJsDocs",
        "title": "Verno: Generate JSDoc (BMAD Agents)"
      },
      {
        "command": "verno.generateJsDocsFile",
        "title": "Verno: Generate JSDoc for Current File"
      },
      {
        "command": "verno.generateChangelog",
        "title": "Verno: Generate Changelog from Git History"
      },
      {
        "command": "verno.toggleMode",
        "title": "Verno: Toggle Chat / SDLC Mode"
      },
      {
        "command": "verno.setupJira",
        "title": "Verno: Setup Jira Integration"
      }
    ],
    "keybindings": [
      {
        "command": "verno.processInput",
        "key": "ctrl+shift+;",
        "mac": "cmd+shift+;"
      },
      {
        "command": "verno.startRecording",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      },
      {
        "command": "verno.startSDLC",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      },
      {
        "command": "verno.toggleMode",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "verno",
          "title": "Verno",
          "icon": "media/logo.png",
          "type": "webview"
        }
      ]
    },
    "views": {
      "verno": [
        {
          "id": "verno.agentPanel",
          "name": "Agent Panel",
          "type": "webview"
        },
        {
          "id": "verno-enhanced-sidebar",
          "name": "Verno Dashboard",
          "type": "webview"
        },
        {
          "id": "verno-coverage-sidebar",
          "name": "Verno Coverage",
          "type": "webview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "verno.agentPanel",
        "contents": "Click the button to activate Verno and load the Agent Panel.\n[Activate Verno](command:verno.processInput)"
      }
    ],
    "configuration": {
      "title": "Verno",
      "properties": {
        "verno.defaultProvider": {
          "type": "string",
          "default": "groq",
          "enum": [
            "gemini",
            "groq",
            "anthropic",
            "openai"
          ],
          "description": "Default AI provider. API keys are stored securely via Verno: Clear Stored API Keys."
        },
        "verno.ttsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Verno to speak responses out loud"
        },
        "verno.ttsVoice": {
          "type": "string",
          "default": "af_heart",
          "description": "Select the Kokoro voice model (e.g., af_heart, af_nicole, af_sky)."
        },
        "verno.ttsSpeed": {
          "type": "number",
          "default": 1.1,
          "description": "Playback speed multiplier for the TTS voice."
        },
        "verno.whisperMode": {
          "type": "string",
          "default": "hybrid",
          "enum": [
            "hybrid",
            "local-only",
            "cloud-only"
          ],
          "description": "hybrid = auto-route for speed | local-only = enterprise privacy | cloud-only = max accuracy"
        },
        "verno.localWhisperModel": {
          "type": "string",
          "default": "base",
          "enum": [
            "tiny",
            "base",
            "small",
            "medium",
            "large-v3"
          ],
          "description": "Local Whisper model size. large-v3 = most accurate, base = fastest"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "sinon": "^21.1.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.54.0",
    "vscode": "^1.1.37"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@ricky0123/vad-web": "^0.0.30",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.5",
    "groq-sdk": "^0.37.0",
    "node-pty": "^1.1.0",
    "onnxruntime-web": "^1.24.3",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.26.6"
  }
}