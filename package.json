{
  "name": "verno",
  "displayName": "verno",
  "description": "a voice agentic coding agent",
  "version": "0.0.1",
  "publisher": "yourname",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "verno.processInput",
        "title": "Verno: Process User Input"
      },
      {
        "command": "verno.startRecording",
        "title": "Verno: Start Recording"
      },
      {
        "command": "verno.stopRecording",
        "title": "Verno: Stop Recording"
      },
      {
        "command": "verno.manageAgents",
        "title": "Verno: Manage Agents"
      },
      {
        "command": "verno.generateCode",
        "title": "Verno: Generate Code"
      },
      {
        "command": "verno.showDiff",
        "title": "Verno: Show Diff"
      },
      {
        "command": "verno.showOutput",
        "title": "Verno: Show Verno Output"
      },
      {
        "command": "verno.revealSidebar",
        "title": "Verno: Reveal Sidebar"
      },
      {
        "command": "verno.newConversation",
        "title": "Verno: New Conversation"
      },
      {
        "command": "verno.processVoiceInput",
        "title": "Verno: Process Voice Input"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "verno",
          "title": "Verno",
          "icon": "media/verno-icon.svg",
          "type": "webview"
        }
      ]
    },
    "views": {
      "verno": [
        {
          "id": "verno.agentPanel",
          "name": "Agent Panel",
          "type": "webview"
        },
        {
          "id": "verno-enhanced-sidebar",
          "name": "Verno Dashboard",
          "type": "webview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "verno.agentPanel",
        "contents": "Click the button to activate Verno and load the Agent Panel.\n[Activate Verno](command:verno.processInput)"
      }
    ],
    "configuration": {
      "title": "Verno",
      "properties": {
        "verno.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for Claude (best coding model)"
        },
        "verno.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API key for LLaMA fallback and cloud STT"
        },
        "verno.ttsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Verno to speak responses out loud"
        },
        "verno.ttsVoice": {
          "type": "string",
          "default": "af_heart",
          "description": "Select the Kokoro voice model (e.g., af_heart, af_nicole, af_sky)."
        },
        "verno.ttsSpeed": {
          "type": "number",
          "default": 1.1,
          "description": "Playback speed multiplier for the TTS voice."
        },
        "verno.whisperMode": {
          "type": "string",
          "default": "hybrid",
          "enum": [
            "hybrid",
            "local-only",
            "cloud-only"
          ],
          "description": "hybrid = auto-route for speed | local-only = enterprise privacy | cloud-only = max accuracy"
        },
        "verno.localWhisperModel": {
          "type": "string",
          "default": "base",
          "enum": [
            "tiny",
            "base",
            "small",
            "medium",
            "large-v3"
          ],
          "description": "Local Whisper model size. large-v3 = most accurate, base = fastest"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.54.0",
    "vscode": "^1.1.37"
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "@xenova/transformers": "^2.17.2",
    "form-data": "^4.0.5",
    "groq-sdk": "^0.37.0",
    "onnxruntime-web": "^1.24.3",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.26.6"
  }
}
